# ── Quant Energy Pipeline — Environment Variables ─────────────────────────────
# Copy this file to .env and fill in real values.
# .env is gitignored and NEVER committed.

# ── Anthropic API (Claude Leadership Agent + CrewAI LLM — primary) ────────────
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── OpenAI API (CrewAI fallback LLM + ChromaDB embeddings) ────────────────────
# Get your key at: https://platform.openai.com/api-keys
# Required for ChromaDB vector embeddings even if Claude is the primary LLM.
OPENAI_API_KEY=sk-your-openai-key-here

# ── EIA Open Data API (live weekly crude storage — crew_agent.py) ──────────────
# Free registration at: https://www.eia.gov/opendata/register.php
EIA_API_KEY=your-eia-api-key-here

# ── Alpaca Markets (PAPER trading only — crew_agent.py) ────────────────────────
# Sign up for a FREE paper account at: https://app.alpaca.markets/signup
# Dashboard → Paper Trading → API Keys → Generate
# CRITICAL: ALPACA_BASE_URL must stay as paper-api.alpaca.markets — never alpaca.markets
ALPACA_API_KEY=your-alpaca-paper-api-key
ALPACA_SECRET_KEY=your-alpaca-paper-secret-key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Interactive Brokers (global_ecosystem.py — paper trading port 4002) ────────
# TWS Paper Trading setup:
#   1. Download TWS: https://www.interactivebrokers.com/en/trading/tws.php
#   2. Log in with your IB paper trading account
#   3. TWS → Edit → Global Configuration → API → Settings
#      ✅ Enable ActiveX and Socket Clients
#      Socket port: 4002
#      ✅ Allow connections from localhost only
#   4. Click OK — system will auto-connect when autonomous_agent.py starts
IB_HOST=127.0.0.1
IB_PORT=4002
IB_CLIENT_ID=10

# ── Discord webhook (crew_agent.py + dashboard.py alert simulator) ─────────────
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

# ── Slack webhook (optional — crew_agent.py + dashboard.py) ───────────────────
# api.slack.com/apps → Incoming Webhooks → Add New Webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook
