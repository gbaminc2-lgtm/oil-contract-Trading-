# ── Quant Energy Pipeline — Environment Variables ─────────────────────────────
# Copy this file to .env and fill in real values.
# .env is gitignored and NEVER committed.

# ── Anthropic API (Claude Leadership Agent — regime detection) ─────────────────
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Interactive Brokers (paper trading only — port 4002) ──────────────────────
# TWS Paper Trading setup:
#   1. Download TWS: https://www.interactivebrokers.com/en/trading/tws.php
#   2. Log in with your IB paper trading account
#   3. TWS → Edit → Global Configuration → API → Settings
#      ✅ Enable ActiveX and Socket Clients
#      Socket port: 4002
#      ✅ Allow connections from localhost only
#   4. Click OK — system will auto-connect when autonomous_agent.py starts
IB_HOST=127.0.0.1
IB_PORT=4002
IB_CLIENT_ID=10

# ── Optional: Discord webhook for trade alerts ─────────────────────────────────
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-here
